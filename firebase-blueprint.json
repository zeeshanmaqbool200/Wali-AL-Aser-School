{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Core identity and profile information for all members.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "manager", "superadmin", "pending_teacher"] },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "photoURL": { "type": "string" },
        "classLevel": { "type": "string" },
        "assignedClasses": { "type": "array" },
        "subjectsEnrolled": { "type": "array" },
        "hardwareStatus": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Receipt": {
      "title": "Fee Receipt",
      "description": "Financial record of payments made by students or others.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "amount": { "type": "number" },
        "feeHead": { "type": "string" },
        "paymentMode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "amount", "status"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Daily attendance tracking for students.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "classLevel": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "late", "leave"] },
        "markedBy": { "type": "string" }
      },
      "required": ["studentId", "date", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection."
    },
    "/receipts/{receiptId}": {
      "schema": "Receipt",
      "description": "Payment records."
    },
    "/attendance/{recordId}": {
      "schema": "Attendance",
      "description": "Daily attendance."
    },
    "/courses/{courseId}": {
      "schema": "object",
      "description": "Mazameen (Courses)."
    }
  }
}
