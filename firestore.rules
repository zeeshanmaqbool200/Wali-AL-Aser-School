rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net (Deny all by default)
    match /{document=**} {
      allow read, write: if false;
    }
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Strictly mandated by integration instructions
    // We check if email is verified.
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Hardened Identity Checks
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'sZUiAgoSF8MTPBQAOtj6jbFkot93' ||
        request.auth.token.get('email', '') == 'zeeshanmaqbool200@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'superadmin')
      );
    }
    
    function isManager() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == 'manager')
      );
    }
    
    function isTeacher() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == 'teacher';
    }

    function isStaff() {
      return isSuperAdmin() || isManager() || isTeacher();
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATION HELPERS (Eight Pillars: Anti-Update-Gap)
    // -------------------------------------------------------------------------
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['student', 'teacher', 'manager', 'superadmin', 'pending_teacher'] &&
             (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!data.keys().contains('phone') || (data.phone is string && data.phone.size() <= 128)) &&
             (!data.keys().contains('updatedAt') || data.updatedAt == request.time);
    }

    function isValidReceipt(data) {
      return data.keys().hasAll(['studentId', 'amount', 'status']) &&
             data.studentId is string && data.studentId.size() <= 128 &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!data.keys().contains('feeHead') || (data.feeHead is string && data.feeHead.size() <= 128));
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isStaff());
      allow list: if isStaff();
      
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming()) && (
        isManager() || (isOwner(userId) && incoming().role in ['student', 'pending_teacher'])
      );
      
      allow update: if isSignedIn() && isValidId(userId) && (
        isSuperAdmin() ||
        (isManager() && incoming().role == existing().role) ||
        (isOwner(userId) && incoming().role == existing().role && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phone', 'whatsapp', 'address', 'photoURL', 'updatedAt', 'notificationPrefs', 'uiPrefs', 'pendingClassLevel', 'classLevel']))
      );
      
      // EXPLICIT BY UID TO OVERRIDE ANY PERMISSION ISSUES
      allow delete: if isSignedIn() && (request.auth.uid == 'sZUiAgoSF8MTPBQAOtj6jbFkot93' || isSuperAdmin());
    }

    // RECEIPTS
    match /receipts/{receiptId} {
      allow read: if isManager() || (isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.createdBy == request.auth.uid));
      allow create: if isStaff() && isValidReceipt(incoming());
      allow update: if isManager() || (isTeacher() && existing().createdBy == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    // ATTENDANCE
    match /attendance/{id} {
      allow read: if isStaff() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create, update: if isStaff();
      allow delete: if isSuperAdmin();
    }

    // EXAMS
    match /exams/{id} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isSuperAdmin();
    }

    // COURSES
    match /courses/{id} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isSuperAdmin();
    }

    // SCHEDULES / EVENTS
    match /schedules/{id} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isSuperAdmin();
    }
    
    match /events/{id} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isSuperAdmin();
    }

    // NOTES
    match /notes/{id} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isSuperAdmin();
    }

    // SETTINGS
    match /settings/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{id} {
      allow read: if isSignedIn();
      allow create: if isStaff();
      allow update, delete: if isSuperAdmin();
    }

    // LOGS
    match /access_logs/{id} {
      allow read: if isStaff();
      allow create: if isSignedIn();
    }

    match /system_logs/{id} {
      allow read: if isSuperAdmin();
      allow create: if true;
    }
  }
}
